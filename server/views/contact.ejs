<%- include('layout') %>

<section class="py-4">
  <h1 class="h2 mb-4">Contact</h1>

  <div class="contact-row row g-4 align-items-stretch" data-aos="fade-up">

    <!-- Left: form -->
    <div class="col-lg-6 d-flex">
      <div class="frame frame--lift p-3 flex-grow-1 d-flex flex-column justify-content-center">

        <form id="contactForm" class="row g-2">

          <div class="col-12">
            <div id="packPillWrap" class="d-none">
              <span class="pack-pill d-inline-flex align-items-center">
                <span class="me-1">Selected:</span>
                <strong id="selectedPackLabel"></strong>
                <button type="button" id="clearPack" class="x-btn ms-2" aria-label="Clear">×</button>
              </span>
            </div>
            <input type="hidden" name="pack" id="selectedPack" />
          </div>

          <div class="col-12">
            <label class="form-label fw-semibold">Name</label>
            <input class="form-control" name="name" required minlength="2" placeholder="Your name" />
          </div>

          <div class="col-12">
            <label class="form-label fw-semibold">Email</label>
            <input class="form-control" name="email" type="email" required placeholder="you@example.com" />
          </div>

          <div class="col-12">
            <label class="form-label fw-semibold">Message</label>
            <textarea class="form-control" name="message" rows="3" required
              minlength="10" maxlength="180"
              style="resize:none; height:100px"
              placeholder="Tell us about your brand, goals, and timeline..."></textarea>
            <div class="d-flex justify-content-end mt-1">
              <span id="charCount" class="text-muted" style="font-size:.78rem">0 / 180</span>
            </div>
          </div>

          <!-- Honeypot -->
          <div style="display:none; visibility:hidden;" aria-hidden="true">
            <input name="company" tabindex="-1" autocomplete="off" />
          </div>

          <div class="col-12">
            <button class="btn btn-primary px-4" type="submit">Send message</button>
            <div id="formStatus" class="mt-2 small"></div>
          </div>

        </form>
      </div>
    </div>

    <!-- Right: brand banner -->
    <div class="col-lg-6 d-flex">
      <div class="contact-banner-wrap flex-grow-1">
        <img src="/images/brand/contact.jpeg"
             alt="Tailored to meet your needs — Carrot Agency">
      </div>
    </div>

  </div>
  <p class="small text-muted mt-2 mb-0">
    By submitting the form you agree to be contacted about your request.
    We don't spam or resell data.
  </p>
</section>



<script src="/js/contact.js" defer></script>
<%- include('partials/footer') %>
