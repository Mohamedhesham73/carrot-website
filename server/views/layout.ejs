<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title><%= title || 'Carrot Agency' %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- PWA -->
  <link rel="manifest" href="/manifest.webmanifest">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="theme-color" content="#FF7F27">
  <meta name="theme-color" media="(prefers-color-scheme: light)" content="#FF7F27">
  <meta name="theme-color" media="(prefers-color-scheme: dark)"  content="#111111">
  <meta name="msapplication-TileColor" content="#FF7F27">

  <!-- SEO -->
  <meta name="description" content="<%= locals.description || 'Carrot Agency — Performance-first marketing for brands that want real growth.' %>" />
  <link rel="canonical" href="<%= process.env.SITE_URL || 'https://YOURDOMAIN.com' %>/" />
  <meta property="og:title"       content="<%= title || 'Carrot Agency — Marketing that Grows' %>" />
  <meta property="og:description" content="<%= locals.description || 'Performance-first marketing without the fluff.' %>" />
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content="<%= process.env.SITE_URL || 'https://YOURDOMAIN.com' %>/" />
  <meta property="og:image"       content="<%= process.env.SITE_URL || 'https://YOURDOMAIN.com' %>/images/brand/cover.jpg" />
  <meta name="twitter:card"       content="summary_large_image" />
  <meta name="twitter:image"      content="<%= process.env.SITE_URL || 'https://YOURDOMAIN.com' %>/images/brand/cover.jpg" />

  <!-- Icons -->
  <link rel="icon" href="/images/brand/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" href="/images/brand/icon-192.png" />
  <link rel="apple-touch-icon" href="/images/brand/apple-touch-icon.png" />

  <!-- CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">
  <link href="/styles/styles.css" rel="stylesheet" />
</head>

<body>
  <header class="site-header sticky-top">
    <nav class="navbar navbar-expand-lg container">
      <a class="navbar-brand d-flex align-items-center" href="/">
        <img src="/images/brand/logo-navbar.png"
             alt="Carrot Agency" class="brand-logo me-2" />
        <span class="visually-hidden">Carrot</span>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
              aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div id="mainNav" class="collapse navbar-collapse">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link <%= page==='home'     ? 'active' : '' %>" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link <%= page==='about'    ? 'active' : '' %>" href="/about">About</a></li>
          <li class="nav-item"><a class="nav-link <%= page==='services' ? 'active' : '' %>" href="/services">Services</a></li>
          <li class="nav-item"><a class="nav-link <%= page==='portfolio'? 'active' : '' %>" href="/portfolio">Portfolio</a></li>
          <li class="nav-item"><a class="nav-link <%= page==='pricing'  ? 'active' : '' %>" href="/pricing">Pricing</a></li>
          <li class="nav-item"><a class="nav-link <%= page==='contact'  ? 'active' : '' %>" href="/contact">Contact</a></li>
        </ul>
        <div class="d-flex align-items-center ms-lg-3">
          <button id="themeToggle" class="btn btn-sm btn-outline-secondary" type="button" aria-label="Toggle theme">
            <span class="theme-icon" aria-hidden="true">🌙</span>
          </button>
        </div>
      </div>
    </nav>
  </header>

  <!-- Page cover (all pages except Home) -->
  <% if (page !== 'home') { %>
  <section class="page-cover page-<%= page %>" data-aos="fade-up">
    <img src="/images/brand/cover.jpg" alt="" class="cover-img">
  </section>
  <% } %>

  <!-- Services orange slice sits here — outside main, directly after cover -->
  <% if (page === 'services') { %>
  <section class="slice slice-orange diagonal-bottom" data-aos="fade-up" style="margin-top:2.5px;">
    <div class="container py-5">
      <h1 class="mb-2">Services</h1>
      <p class="lead mb-3">Pick a pillar or blend them — fast iteration, clear reporting, measurable growth.</p>
      <nav class="subnav">
        <a href="#smm">SMM</a>
        <a href="#seo">SEO</a>
        <a href="#ads">ADS</a>
        <a href="#web">WEB</a>
        <a href="#addons">Packages</a>
      </nav>
    </div>
  </section>
  <% } %>

  <main class="<%= page === 'home' ? 'p-0' : 'container py-5' %>">
